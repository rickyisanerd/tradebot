# ── Broker Mode ─────────────────────────────────────────────
# demo | paper | live
BROKER_MODE=demo
ALPACA_KEY_ID=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here

# ── Auto Trading ───────────────────────────────────────────
AUTO_TRADE_ENABLED=true
AUTO_TRADE_INTERVAL_MINUTES=30
PDT_COOLDOWN_HOURS=20

# ── Position Sizing & Risk ─────────────────────────────────
# The bot auto-scales these limits as equity grows.
MAX_TOTAL_CAPITAL=500
MAX_OPEN_POSITIONS=5
MAX_NEW_POSITIONS_PER_RUN=3
RISK_PER_TRADE_PCT=0.04
MAX_POSITION_PCT=0.25
MIN_REWARD_RISK=1.2
# Accepts either 8 or 0.08 for an 8% stop.
STOP_LOSS_PCT=0.08
USE_BROKER_PROTECTIVE_ORDERS=true
MIN_HOLD_DAYS=1
MAX_HOLD_DAYS=10

# ── Universe Scanning ──────────────────────────────────────
MAX_STOCK_PRICE=10
MIN_STOCK_PRICE=1
CANDIDATE_LIMIT=12
MIN_DOLLAR_VOLUME=1000000
LOOKBACK_DAYS=80
# Optional comma-separated override
# SCAN_UNIVERSE=SOFI,PLUG,RIVN,LCID,NOK

# ── Congress Signals ───────────────────────────────────────
CONGRESS_MAX_PRICE=20
CONGRESS_TRADE_LIMIT=20
CONGRESS_SIGNAL_WINDOW_DAYS=45
CONGRESS_FRESHNESS_HOURS=24
CONGRESS_MIN_RECORDS=1
CONGRESS_RETRY_MINUTES=15
CONGRESS_OVERRIDE_MODE=auto
DECISION_SUPPORT_CONGRESS_WEIGHT=1.0
# Optional comma-separated list of official House/Senate PTR PDF URLs.
# CONGRESS_REPORT_URLS=https://disclosures-clerk.house.gov/public_disc/ptr-pdfs/2026/20033918.pdf

# ── SEC Signals ────────────────────────────────────────────
SEC_USER_AGENT=
SEC_SIGNAL_WINDOW_DAYS=30
SEC_FILING_LIMIT_PER_SYMBOL=20
SEC_FRESHNESS_HOURS=24
SEC_MIN_RECORDS=1
SEC_RETRY_MINUTES=15
SEC_OVERRIDE_MODE=auto
DECISION_SUPPORT_SEC_WEIGHT=1.0

# ── Earnings Signals ──────────────────────────────────────
ALPHA_VANTAGE_API_KEY=
EARNINGS_SIGNAL_WINDOW_DAYS=21
EARNINGS_FRESHNESS_HOURS=24
EARNINGS_MIN_RECORDS=1
EARNINGS_RETRY_MINUTES=15
EARNINGS_OVERRIDE_MODE=auto
DECISION_SUPPORT_EARNINGS_WEIGHT=1.0

# ── Macro Signals ─────────────────────────────────────────
MACRO_SIGNAL_WINDOW_DAYS=7
MACRO_FRESHNESS_HOURS=24
MACRO_MIN_RECORDS=1
MACRO_RETRY_MINUTES=15
MACRO_OVERRIDE_MODE=auto
DECISION_SUPPORT_MACRO_WEIGHT=1.0

# ── Demo Mode ─────────────────────────────────────────────
STARTING_CASH=500
DEMO_SEED=42

# ── Dashboard ─────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8008
ANALYZER_MODE=embedded

# ── Railway Deployment ────────────────────────────────────
# Railway injects PORT automatically, and the app respects that.
# If you mount a Railway volume, point DATA_DIR at it so SQLite persists.
# DATA_DIR=/data

# ── Presets ───────────────────────────────────────────────
#
# Small Account Aggressive ($500 start):
#   BROKER_MODE=paper
#   MAX_STOCK_PRICE=10
#   MIN_STOCK_PRICE=1
#   MAX_TOTAL_CAPITAL=500
#   MAX_OPEN_POSITIONS=5
#   MAX_NEW_POSITIONS_PER_RUN=3
#   RISK_PER_TRADE_PCT=0.04
#   MAX_POSITION_PCT=0.25
#   MIN_REWARD_RISK=1.2
#   STOP_LOSS_PCT=0.08
#   MIN_HOLD_DAYS=1
#   MAX_HOLD_DAYS=10
#   AUTO_TRADE_ENABLED=true
#   AUTO_TRADE_INTERVAL_MINUTES=30
#   USE_BROKER_PROTECTIVE_ORDERS=true
#
# Cautious Railway Paper:
#   BROKER_MODE=paper
#   ALPACA_KEY_ID=your_paper_key
#   ALPACA_SECRET_KEY=your_paper_secret
#   DATA_DIR=/data
#   AUTO_TRADE_ENABLED=false
#   MAX_TOTAL_CAPITAL=1000
#   MAX_OPEN_POSITIONS=1
#   MAX_NEW_POSITIONS_PER_RUN=1
#   MAX_POSITION_PCT=0.10
#   RISK_PER_TRADE_PCT=0.005
#   STOP_LOSS_PCT=0.05
#   USE_BROKER_PROTECTIVE_ORDERS=true
#   MIN_HOLD_DAYS=1
#   MAX_HOLD_DAYS=5
#   SEC_USER_AGENT=TradeBot MCP your-email@example.com
#   ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
#
# Cautious Railway Live:
#   BROKER_MODE=live
#   ALPACA_KEY_ID=your_live_key
#   ALPACA_SECRET_KEY=your_live_secret
#   DATA_DIR=/data
#   AUTO_TRADE_ENABLED=false
#   MAX_TOTAL_CAPITAL=1000
#   MAX_OPEN_POSITIONS=1
#   MAX_NEW_POSITIONS_PER_RUN=1
#   MAX_POSITION_PCT=0.10
#   RISK_PER_TRADE_PCT=0.005
#   STOP_LOSS_PCT=0.05
#   USE_BROKER_PROTECTIVE_ORDERS=true
#   MIN_HOLD_DAYS=1
#   MAX_HOLD_DAYS=5
#   SEC_USER_AGENT=TradeBot MCP your-email@example.com
#   ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
