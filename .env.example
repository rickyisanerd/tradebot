# demo | paper | live
BROKER_MODE=demo
ALPACA_KEY_ID=
ALPACA_SECRET_KEY=
AUTO_TRADE_ENABLED=false
AUTO_TRADE_INTERVAL_MINUTES=60
CONGRESS_MAX_PRICE=20
CONGRESS_TRADE_LIMIT=20
# Optional comma-separated list of official House/Senate PTR PDF URLs.
# CONGRESS_REPORT_URLS=https://disclosures-clerk.house.gov/public_disc/ptr-pdfs/2026/20033918.pdf
# Accepts either 5 or 0.05 for a 5% stop.
STOP_LOSS=12
USE_BROKER_PROTECTIVE_ORDERS=true
MIN_HOLD_DAYS=1
MAX_HOLD_DAYS=0
MAX_TOTAL_CAPITAL=0
MAX_OPEN_POSITIONS=0
MAX_STOCK_PRICE=20
MIN_STOCK_PRICE=2
SCAN_LIMIT=40
CANDIDATE_LIMIT=12
MAX_NEW_POSITIONS_PER_RUN=3
RISK_PER_TRADE_PCT=0.01
MAX_POSITION_PCT=0.10
MIN_REWARD_RISK=1.8
MIN_DOLLAR_VOLUME=1000000
LOOKBACK_DAYS=80
STARTING_CASH=100000
DEMO_SEED=42
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8008
ANALYZER_MODE=embedded
# Optional comma-separated override
# SCAN_UNIVERSE=SOFI,PLUG,RIVN,LCID,NOK

# Railway notes:
# Railway injects PORT automatically, and the app now respects that.
# If you mount a Railway volume, point DATA_DIR at it so SQLite persists across deploys.
# DATA_DIR=/data
